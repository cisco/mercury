# Minimal makefile for Sphinx documentation
#
# This Makefile is generated by Sphinx and lives standalone in
# doc/sphinx/.  It is invoked by the top-level mercury Makefile via
# mk/doc.mk, which runs `cd doc/sphinx && $(MAKE) html` for the
# `sphinx` target and `cd doc/sphinx && $(MAKE) clean` for
# `clean-sphinx`.  It can also be invoked directly for local
# documentation work.
#

# You can set these variables from the command line, and also
# from the environment for the first two.
SPHINXOPTS    ?=
SPHINXBUILD   ?= sphinx-build
SOURCEDIR     = source
BUILDDIR      = build

# Put it first so that "make" without argument is like "make help".
help:
	@$(SPHINXBUILD) -M help "$(SOURCEDIR)" "$(BUILDDIR)" $(SPHINXOPTS) $(O)

.PHONY: help Makefile doxyxml

doxyxml:
	doxygen

# Catch-all target: route all unknown targets to Sphinx using the new
# "make mode" option.  $(O) is meant as a shortcut for $(SPHINXOPTS).
#
%: Makefile doxyxml
	@$(SPHINXBUILD) -M $@ "$(SOURCEDIR)" "$(BUILDDIR)" $(SPHINXOPTS) $(O)

.PHONY: clean
clean:
	rm -rf ./source/doxyxml/xml
	rm -rf ./source/doxyxml/latex
	rm -rf ./source/_static
	rm -rf ./source/_templates
	rm -rf ./build/doctrees
	rm -rf ./build/html
	rm -rf ./build/breathe
