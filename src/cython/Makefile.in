# Makefile for cython interface to mercury
#

CXX = @CXX@

openssl_v1_1_or_newer = @OPENSSL_V1_1_OR_NEWER@
openssl_v3_0_or_newer = @OPENSSL_V3_0_OR_NEWER@
is_macos_arm = @IS_MACOS_ARM@
have_xsimd = @HAVE_XSIMD@
xsimd_include = @XSIMD_INCLUDE@

# OpenSSL 3.0 is default (no flag needed)
ifeq ($(openssl_v3_0_or_newer),yes)
	# No flag for OpenSSL 3.0+ (default)
	FLAGS =
else ifeq ($(openssl_v1_1_or_newer),yes)
	FLAGS = -DOPENSSL_V1_1
else
	FLAGS = -DOPENSSL_LEGACY
endif

FLAGS += -O3
# Enable SIMD-accelerated classifier path when xsimd is available on the system.
ifeq ($(have_xsimd),yes)
FLAGS += -DHAVE_XSIMD
ifneq ($(xsimd_include),)
FLAGS += -I$(xsimd_include)
endif
endif

ifeq ($(is_macos_arm),yes)
CFLAGS += -I/opt/homebrew/include
CXXFLAGS += -I/opt/homebrew/include
LDFLAGS += -L/opt/homebrew/lib
endif

UNAME := $(shell uname -s)
ifeq ($(UNAME),Darwin)
    FLAGS += -mmacos-version-min=10.13
endif

# version and git information (mirroring src/libmerc/Makefile.in)
major=$(shell cat ../../VERSION | grep -o "^[0-9]*")
minor=$(subst .,,$(shell cat ../../VERSION | grep -o "\.[0-9]*\."))
patch=$(shell cat ../../VERSION | grep -o "[0-9]*$$")
FLAGS += "-DMERCURY_SEMANTIC_VERSION=$(major),$(minor),$(patch)"

# Embed the git state into compiled objects.
# GIT_COMMIT_ID identifies the source: full SHA-1 hash, plus
#   "with local changes" when the working tree is dirty.
# GIT_COUNT is the total number of commits on HEAD.
# NOTE: keep in sync with src/libmerc/Makefile.in and
#   src/libmerc/CMakeLists.txt, which compute the same defines.
GIT_HASH  := $(shell git rev-parse HEAD 2>/dev/null || echo unknown)
GIT_DIRTY := $(shell git diff --quiet HEAD 2>/dev/null; echo $$?)
GIT_COUNT := $(shell git rev-list --count HEAD 2>/dev/null || echo 0)
ifeq ($(GIT_DIRTY),1)
  GIT_COMMIT_STR := commit $(GIT_HASH) with local changes
else
  # exit 0 = clean, exit >1 = not a git repo / no HEAD — treat as clean
  GIT_COMMIT_STR := commit $(GIT_HASH)
endif
FLAGS += "-DGIT_COMMIT_ID=\"$(GIT_COMMIT_STR)\"" "-DGIT_COUNT=$(GIT_COUNT)"

export ENV_CFLAGS=${FLAGS}

all:
	CC=$(CXX) CXX=$(CXX) CFLAGS="$(CFLAGS)" CXXFLAGS="$(CXXFLAGS)" LDFLAGS="$(LDFLAGS)" python3 setup.py build_ext --inplace

wheel:
	CC=$(CXX) CXX=$(CXX) CFLAGS="$(CFLAGS)" CXXFLAGS="$(CXXFLAGS)" LDFLAGS="$(LDFLAGS)" python3 setup.py bdist_wheel

clean:
	rm -rf mercury.*.so mercury.cpp build dist mercury_python.egg-info *.dSYM
	find . -type d -name "*.dSYM" -prune -exec rm -rf {} +

# EOF
